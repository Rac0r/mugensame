---
layout: base.njk
title: Field Notes
permalink: "/posts/{% if pagination.pageNumber > 0 %}{{ pagination.pageNumber + 1 }}/{% endif %}"
pagination:
  data: collections.posts
  size: 5
  alias: posts
---
<section>
  <p class="eyebrow">Sonar log</p>
  <h1>Field notes from the deep</h1>

  <div class="post-list">
    {%- for post in posts -%}
    <article class="contact-card">
      <a href="{{ post.url | url }}">
        <span class="ping" aria-hidden="true"></span>
        <div>
          <h2>{{ post.data.title }}</h2>
          <p class="meta">{{ post.date | readableDate }}
            {%- if post.data.tags %} ·
            {%- for tag in post.data.tags %}{% if tag != "posts" %} #{{ tag }}{% endif %}{% endfor -%}
            {% endif %}
          </p>
          <p class="excerpt">{{ post.data.description }}</p>
        </div>
      </a>
    </article>
    {%- endfor -%}
  </div>

  <nav class="depth-pagination">
    {%- if pagination.href.previous -%}
    <a href="{{ pagination.href.previous | url }}">↑ Ascend to newer notes</a>
    {%- endif -%}
    {%- if pagination.href.next -%}
    <a href="{{ pagination.href.next | url }}">Descend to older notes ↓</a>
    {%- endif -%}
  </nav>
</section>
