---
layout: base.njk
title: Home
permalink: /
---
<section class="hero">
  <svg class="hero-fin" viewBox="0 0 215 140" aria-hidden="true">
    <path d="M205,72 Q165,42 105,48 Q65,52 40,72 Q65,90 105,96 Q165,100 205,72 Z"/>
    <path d="M115,50 L127,4 C145,10 157,28 163,48 Z"/>
    <path d="M57,64 Q20,35 7,15 Q25,40 37,58 Q20,75 13,105 Q40,95 59,76 Z"/>
    <path d="M165,86 C177,98 187,112 193,124 C183,114 171,104 159,94 Z"/>
  </svg>

  <p class="eyebrow">Depth log · est. {{ site.year }}</p>
  <h1>{{ site.title }}</h1>
  <p class="hero-sub">{{ site.description }}</p>
  <a class="cta" href="{{ '/posts/' | url }}">Read the field notes →</a>
</section>

<section class="latest">
  <p class="eyebrow">Latest contacts</p>
  <div class="post-list">
    {%- for post in collections.posts | limit(3) -%}
    <article class="contact-card">
      <a href="{{ post.url | url }}">
        <span class="ping" aria-hidden="true"></span>
        <div>
          <h2>{{ post.data.title }}</h2>
          <p class="meta">{{ post.date | readableDate }}</p>
          <p class="excerpt">{{ post.data.description }}</p>
        </div>
      </a>
    </article>
    {%- endfor -%}
  </div>
</section>
