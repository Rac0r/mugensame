<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} — {% endif %}{{ site.title }}</title>
  <meta name="description" content="{{ description or site.description }}">

  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 215 140'%3E%3Cg fill='%235EEAD4'%3E%3Cpath d='M205,72 Q165,42 105,48 Q65,52 40,72 Q65,90 105,96 Q165,100 205,72 Z'/%3E%3Cpath d='M115,50 L127,4 C145,10 157,28 163,48 Z'/%3E%3Cpath d='M57,64 Q20,35 7,15 Q25,40 37,58 Q20,75 13,105 Q40,95 59,76 Z'/%3E%3Cpath d='M165,86 C177,98 187,112 193,124 C183,114 171,104 159,94 Z'/%3E%3C/g%3E%3C/svg%3E">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="{{ '/css/style.css' | url }}">
  <link rel="alternate" type="application/rss+xml" title="{{ site.title }} RSS Feed" href="{{ '/feed.xml' | url }}">
</head>
<body>

  <div class="depth-gauge" aria-hidden="true">
    <span class="depth-tick"></span>
    <span class="depth-readout">0m</span>
  </div>

  <header class="site-header" id="site-header">
    <a class="brand" href="{{ '/' | url }}">
      <svg class="fin-mark" viewBox="0 0 215 140" aria-hidden="true">
        <path d="M205,72 Q165,42 105,48 Q65,52 40,72 Q65,90 105,96 Q165,100 205,72 Z"/>
        <path d="M115,50 L127,4 C145,10 157,28 163,48 Z"/>
        <path d="M57,64 Q20,35 7,15 Q25,40 37,58 Q20,75 13,105 Q40,95 59,76 Z"/>
        <path d="M165,86 C177,98 187,112 193,124 C183,114 171,104 159,94 Z"/>
      </svg>
      <span>{{ site.title }}</span>
    </a>
    <nav class="site-nav">
      <a href="{{ '/posts/' | url }}">Field Notes</a>
      <a href="{{ '/tags/' | url }}">Tags</a>
      <a href="{{ '/about/' | url }}">About</a>
    </nav>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <svg class="wave" viewBox="0 0 1200 60" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0,30 C150,60 350,0 600,30 C850,60 1050,0 1200,30 L1200,60 L0,60 Z"/>
    </svg>
    <div class="footer-inner">
      <p>&copy; {{ site.year }} {{ site.title }}. Built with Eleventy.</p>
      <div class="footer-links">
        <a href="{{ '/feed.xml' | url }}">RSS</a>
        <a href="{{ '/' | url }}" class="back-to-surface">↑ Back to the surface</a>
      </div>
    </div>
  </footer>

  <script src="{{ '/js/depth.js' | url }}" defer></script>
</body>
</html>
